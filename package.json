{
  "name": "@statechange/council",
  "version": "0.9.1",
  "description": "CLI + GUI for orchestrating round-robin AI councilor discussions with structured debate and freeform modes",
  "type": "module",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "bin": {
    "council": "./dist/cli.js"
  },
  "files": [
    "assets/",
    "dist/",
    "dist-electron/",
    "dist-renderer/",
    "council/creative/",
    "council/critic/",
    "council/strategist/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/statechange/ai-council.git"
  },
  "keywords": [
    "ai",
    "council",
    "debate",
    "llm",
    "multi-agent",
    "anthropic",
    "openai",
    "google",
    "ollama",
    "claude-code",
    "skills"
